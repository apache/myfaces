/*
 * tsconfig for api-extractor only.
 * api-extractor analyses the pre-emitted declaration tree (mainEntryPointFilePath
 * in api-extractor.faces.json); this compiler program only needs a single stub
 * input. The local @types/definitions typeRoot is dropped here on purpose: its
 * index.d.ts imports from the source _api.ts and would pull raw .ts files into
 * the program (ae-wrong-input-file-type). The tsc --emitDeclarationOnly step
 * keeps using tsconfig.dts.json.
 */
{
  "extends": "./tsconfig.dts.json",
  "compilerOptions": {
    "typeRoots": ["./node_modules/@types"],
    "types": ["node"]
  },
  "include": ["typescript/faces/api/_api_ae_stub.d.ts"]
}
