{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",

  // The client root has no plain tsconfig.json (only tsconfig-*.json), so the
  // default "<lookup>" cannot locate the project folder — set it explicitly.
  "projectFolder": ".",

  "mainEntryPointFilePath": "<projectFolder>/dts-build/typescript/faces/api/_api.d.ts",

  "compiler": {
    "tsconfigFilePath": "<projectFolder>/tsconfig.ae.json"
  },

  "apiReport": {
    "enabled": false
  },

  "docModel": {
    "enabled": false
  },

  "dtsRollup": {
    "enabled": true,
    "untrimmedFilePath": "",
    "publicTrimmedFilePath": "<projectFolder>/../../target/classes/META-INF/resources/jakarta.faces/faces.d.ts"
  },

  "tsdocMetadata": {
    "enabled": false
  },

  "messages": {
    "extractorMessageReporting": {
      "ae-missing-release-tag": { "logLevel": "none" },
      "ae-internal-missing-underscore": { "logLevel": "none" },
      "ae-forgotten-export": { "logLevel": "none" }
    },
    "tsdocMessageReporting": {
      "default": { "logLevel": "none" }
    }
  }
}
