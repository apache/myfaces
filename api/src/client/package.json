  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@types/chai": "^4.3.4",
    "@types/fs-extra": "^11.0.1",
    "@types/mocha": "^10.0.1",
    "@types/node": "^18.15.12",
    "@types/sinon": "^10.0.14",
    "babel-plugin-syntax-dynamic-import": "^6.18.0",
    "chai": "^4.3.7",
    "compression-webpack-plugin": "^10.0.0",
    "cross-env": "^7.0.3",
    "fs-extra": "^11.1.1",
    "html-webpack-plugin": "^5.5.1",
    "global-jsdom": "^29.0.0",
    "jsdom": "^29.1.0",
    "jsf.js_next_gen": "4.1.0-beta.9",
    "mocha": "^11.7.5",
    "npm-check-updates": "^22.0.1",
    "nyc": "^18.0.0",
