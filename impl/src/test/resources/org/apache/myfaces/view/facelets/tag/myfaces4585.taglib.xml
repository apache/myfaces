<facelet-taglib version="2.0"
        xmlns="http://java.sun.com/xml/ns/javaee"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-facelettaglibrary_2_0.xsd">
    <!-- Same namespace URI as primefaces-test expression-error-method-not-found / WEB-INF taglib -->
    <namespace>http://at.test.test/jsf-taglib</namespace>
    <tag>
        <tag-name>panel</tag-name>
        <source>myfaces4585_taglib_panel.xhtml</source>
        <attribute>
            <name>id</name>
            <type>java.lang.String</type>
            <required>true</required>
        </attribute>
        <attribute>
            <name>header</name>
            <type>java.lang.String</type>
        </attribute>
    </tag>
    <tag>
        <tag-name>autoCompleteBase</tag-name>
        <source>myfaces4585_autoCompleteBase.xhtml</source>
        <attribute>
            <name>value</name>
            <required>true</required>
            <type>java.lang.Object</type>
        </attribute>
        <attribute>
            <name>converter</name>
            <type>jakarta.faces.convert.Converter</type>
            <required>true</required>
        </attribute>
    </tag>
</facelet-taglib>
